# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_VERSION=2023-06-01
CLAUDE_MODEL=claude-sonnet-4-6

# Twitter / X — server-side only, never expose to client
TWITTER_API_KEY=your_api_key_here
TWITTER_API_SECRET=your_api_secret_here
TWITTER_ACCESS_TOKEN=your_access_token_here
TWITTER_ACCESS_TOKEN_SECRET=your_access_token_secret_here

# Postgres — Neon free tier recommended (https://neon.tech)
DATABASE_URL=postgres://user:pass@host.neon.tech/vionyx?sslmode=require

# Cron security — generate a random 32+ char string, set same value in Vercel dashboard
CRON_SECRET=generate_a_random_32char_string_here

# CORS — set to your frontend origin in production (e.g. https://app.vionyx.com)
ALLOWED_ORIGIN=http://localhost:3000
